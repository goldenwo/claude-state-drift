{
  "hooks": {
    "SessionStart": [
      { "hooks": [ {
        "type": "command",
        "command": "bash $CODEX_STATE_DRIFT_HOME/run-hook.sh session-start-orient.sh",
        "commandWindows": "bash $CODEX_STATE_DRIFT_HOME_WIN/run-hook.sh session-start-orient.sh",
        "timeout": 15,
        "statusMessage": "claude-state-drift: orientation"
      } ] }
    ],
    "PostToolUse": [
      { "matcher": "Bash", "hooks": [ {
        "type": "command",
        "command": "bash $CODEX_STATE_DRIFT_HOME/run-hook.sh state-track-commit.sh",
        "commandWindows": "bash $CODEX_STATE_DRIFT_HOME_WIN/run-hook.sh state-track-commit.sh",
        "timeout": 15,
        "statusMessage": "claude-state-drift: commit-transition"
      } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ {
        "type": "command",
        "command": "bash $CODEX_STATE_DRIFT_HOME/run-hook.sh focus-check.sh",
        "commandWindows": "bash $CODEX_STATE_DRIFT_HOME_WIN/run-hook.sh focus-check.sh",
        "timeout": 10,
        "statusMessage": "claude-state-drift: focus-check"
      } ] }
    ],
    "Stop": [
      { "hooks": [ {
        "type": "command",
        "command": "bash $CODEX_STATE_DRIFT_HOME/run-hook.sh state-staleness.sh",
        "commandWindows": "bash $CODEX_STATE_DRIFT_HOME_WIN/run-hook.sh state-staleness.sh",
        "timeout": 15,
        "statusMessage": "claude-state-drift: staleness"
      } ] }
    ]
  }
}
