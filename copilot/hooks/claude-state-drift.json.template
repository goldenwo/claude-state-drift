{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "$COPILOT_STATE_DRIFT_HOME/orient-hook.sh",
        "powershell": "$env:COPILOT_STATE_DRIFT_HOME/orient-hook.ps1",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "$COPILOT_STATE_DRIFT_HOME/transition-hook.sh",
        "powershell": "$env:COPILOT_STATE_DRIFT_HOME/transition-hook.ps1",
        "cwd": ".",
        "timeoutSec": 15
      }
    ]
  }
}
